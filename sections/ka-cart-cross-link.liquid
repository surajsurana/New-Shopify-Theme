{{ 'ka-cart-cross-link.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  K&A Cart ("Bag") Cross-link section.
  Spec: Docs/cart-build-spec.md Section 3, F6/F10.
  Two copy variants server-rendered based on cart.item_count:
  - Filled cart: "You May Also Love" / "From the Same Atelier"
  - Empty cart:  "Begin Here" / "Recently Loved"
  Collection-driven fallback logic below.
{%- endcomment -%}

{%- liquid
  assign is_empty = false
  if cart.item_count == 0
    assign is_empty = true
  endif

  assign cross_collection = section.settings.collection
  if cross_collection == blank
    assign cross_collection = collections['bestsellers']
  endif
-%}

<section class="ka-cart-cross" aria-label="Recommended pieces">
  <div class="ka-cart-cross__header">
    {% if is_empty %}
      <p class="eyebrow eyebrow--muted reveal">{{ section.settings.empty_eyebrow | default: 'Recently Loved' }}</p>
      <h2 class="ka-cart-cross__title reveal reveal-delay-1">{{ section.settings.empty_title | default: 'Begin Here' }}</h2>
    {% else %}
      <p class="eyebrow eyebrow--muted reveal">{{ section.settings.filled_eyebrow | default: 'From the Same Atelier' }}</p>
      <h2 class="ka-cart-cross__title reveal reveal-delay-1">{{ section.settings.filled_title | default: 'You May Also Love' }}</h2>
    {% endif %}
  </div>

  <div class="ka-cart-cross__grid">
    {% for product in cross_collection.products limit: 4 %}
      <div class="ka-cart-cross__card reveal-img reveal-delay-{{ forloop.index | modulo: 4 }}">
        <a href="{{ product.url }}" class="ka-cart-cross__image" aria-label="View {{ product.title | escape }}">
          {% if product.featured_image %}
            <img
              src="{{ product.featured_image | image_url: width: 600 }}"
              alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
              loading="lazy"
              width="600"
              height="800"
            />
          {% endif %}
        </a>
        <div class="ka-cart-cross__info">
          <h3 class="ka-cart-cross__name"><a href="{{ product.url }}">{{ product.title }}</a></h3>
          <p class="ka-cart-cross__price">{{ product.price | money }}</p>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Cart Cross-link",
  "tag": "section",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Leave blank to default to the 'bestsellers' collection."
    },
    { "type": "header", "content": "Filled-cart copy" },
    { "type": "text", "id": "filled_eyebrow", "label": "Eyebrow", "default": "From the Same Atelier" },
    { "type": "text", "id": "filled_title",   "label": "Title",   "default": "You May Also Love" },
    { "type": "header", "content": "Empty-cart copy" },
    { "type": "text", "id": "empty_eyebrow", "label": "Eyebrow", "default": "Recently Loved" },
    { "type": "text", "id": "empty_title",   "label": "Title",   "default": "Begin Here" }
  ],
  "presets": [
    { "name": "Cart Cross-link" }
  ]
}
{% endschema %}
