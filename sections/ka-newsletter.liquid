{{ 'ka-newsletter.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  F3 assumption: Defaulting to Shopify native customer email subscribe.
  Form action="/contact#contact_form", method POST, with hidden contact[tags] field.
  Success state handled by checking form.posted_successfully? in Liquid.

  TO SWAP FOR KLAVIYO: Replace the {% form 'customer' %} block with
  the Klaviyo embed snippet. The .ka-newsletter__form CSS will need
  to override Klaviyo's injected wrappers — test carefully.
{%- endcomment -%}

<section class="ka-newsletter" aria-label="Join the correspondence list">
  <div class="ka-newsletter__inner">
    <p class="eyebrow eyebrow--on-dark ka-newsletter__eyebrow reveal">{{ section.settings.eyebrow }}</p>
    <h2 class="ka-newsletter__title reveal reveal-delay-1">{{ section.settings.title }}</h2>
    <p class="ka-newsletter__body reveal reveal-delay-2">{{ section.settings.body }}</p>

    {% form 'customer', class: 'ka-newsletter__form reveal reveal-delay-3' %}
      {% if form.posted_successfully? %}
        <p class="ka-newsletter__success">{{ section.settings.success_message }}</p>
      {% else %}
        <input type="hidden" name="contact[tags]" value="newsletter,ka-correspondence" />
        <input
          type="email"
          name="contact[email]"
          class="ka-newsletter__input"
          placeholder="{{ section.settings.input_placeholder }}"
          aria-label="{{ section.settings.input_placeholder }}"
          required
        />
        <button type="submit" class="ka-newsletter__submit">{{ section.settings.submit_label }}</button>
      {% endif %}
    {% endform %}

    <p class="ka-newsletter__note reveal reveal-delay-4">{{ section.settings.note }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    { "type": "text",     "id": "eyebrow",           "label": "Eyebrow",           "default": "From the Atelier" },
    { "type": "text",     "id": "title",             "label": "Title",             "default": "Receive our\nCorrespondence" },
    { "type": "textarea", "id": "body",              "label": "Body text",         "default": "Collection stories, styling notes, and invitations to our trunk shows — delivered quietly to your inbox. No promotions. Only beauty." },
    { "type": "text",     "id": "input_placeholder", "label": "Input placeholder", "default": "Your email address" },
    { "type": "text",     "id": "submit_label",      "label": "Submit button",     "default": "Subscribe" },
    { "type": "text",     "id": "success_message",   "label": "Success message",   "default": "Thank you. You are on the list." },
    { "type": "text",     "id": "note",              "label": "Fine print note",   "default": "We send four letters a year. Unsubscribe at any time." }
  ],
  "presets": [
    { "name": "Newsletter" }
  ]
}
{% endschema %}
