{{ 'ka-footer.css' | asset_url | stylesheet_tag }}

<footer class="ka-footer" aria-label="Site footer">
  <div class="ka-footer__top">
    <!-- Column 1: Brand -->
    <div class="ka-footer__brand">
      <span class="ka-footer__logo">{{ section.settings.brand_name }}<small>{{ section.settings.logo_subline }}</small></span>
      <p class="ka-footer__tagline">{{ section.settings.tagline | newline_to_br }}</p>
      <div class="ka-footer__social">
        {% if section.settings.instagram_url != blank %}
          <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener">Instagram</a>
        {% endif %}
        <a href="https://wa.me/{{ settings.whatsapp_number }}" target="_blank" rel="noopener">Concierge</a>
        {% if section.settings.pinterest_url != blank %}
          <a href="{{ section.settings.pinterest_url }}" target="_blank" rel="noopener">Pinterest</a>
        {% endif %}
      </div>
    </div>

    <!-- Column 2: Collections -->
    <div>
      <p class="ka-footer__col-title">Collections</p>
      <ul class="ka-footer__links">
        {% for link in linklists['footer-collections'].links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
        {% if linklists['footer-collections'].links.size == 0 %}
          <li><a href="/collections/the-festive-edit">The Festive Edit</a></li>
          <li><a href="/collections/the-bloom-soiree">The Bloom Soirée</a></li>
          <li><a href="/collections/chamak">Chamakk</a></li>
          <li><a href="/collections/barre-oblique">Barre Oblique</a></li>
          <li><a href="/collections/bestsellers">Signature</a></li>
        {% endif %}
      </ul>
    </div>

    <!-- Column 3: Maison -->
    <div>
      <p class="ka-footer__col-title">Maison</p>
      <ul class="ka-footer__links">
        {% for link in linklists['footer-the-house'].links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
        {% if linklists['footer-the-house'].links.size == 0 %}
          <li><a href="/pages/about">About Karishma &amp; Ashita</a></li>
          <li><a href="/pages/client-diaries">Client Diaries</a></li>
          <li><a href="/pages/appointments">Book an Appointment</a></li>
          <li><a href="https://wa.me/{{ settings.whatsapp_number }}" target="_blank" rel="noopener">Concierge</a></li>
          <li><a href="/pages/press">Press</a></li>
        {% endif %}
      </ul>
    </div>

    <!-- Column 4: Contact -->
    <div>
      <p class="ka-footer__col-title">Contact</p>
      <div class="ka-footer__contact">
        {% if settings.whatsapp_number != blank %}
          <p class="ka-footer__contact-item">
            <a href="https://wa.me/{{ settings.whatsapp_number }}">{{ settings.whatsapp_display }}</a>
          </p>
        {% endif %}
        {% if section.settings.email != blank %}
          <p class="ka-footer__contact-item">
            <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
          </p>
        {% endif %}
        <p class="ka-footer__contact-item">{{ section.settings.address | newline_to_br }}</p>
      </div>
    </div>

    <!-- Column 5: Inner Circle (newsletter) -->
    <div class="ka-footer__news">
      <p class="ka-footer__col-title">{{ section.settings.news_title }}</p>
      <p>{{ section.settings.news_body }}</p>
      {%- comment -%}
        Defaults to Shopify native customer email subscribe. To swap for
        Klaviyo, replace this {% form 'customer' %} block with the embed.
      {%- endcomment -%}
      {% form 'customer', class: 'ka-footer__news-form' %}
        {% if form.posted_successfully? %}
          <p class="ka-footer__news-success">{{ section.settings.news_success }}</p>
        {% else %}
          <input type="hidden" name="contact[tags]" value="newsletter,ka-correspondence" />
          <input
            type="email"
            name="contact[email]"
            class="ka-footer__news-input"
            placeholder="{{ section.settings.news_placeholder }}"
            aria-label="{{ section.settings.news_placeholder }}"
            required
          />
          <button type="submit" class="ka-footer__news-submit">{{ section.settings.news_submit }}</button>
        {% endif %}
      {% endform %}
    </div>
  </div>

  <div class="ka-footer__bottom">
    <div class="ka-footer__bottom-row">
      <p class="ka-footer__copy">&copy; {{ 'now' | date: '%Y' }} {{ section.settings.brand_name }}. All rights reserved.</p>
      <ul class="ka-footer__legal">
        <li><a href="{{ section.settings.privacy_url | default: '/policies/privacy-policy' }}">Privacy Policy</a></li>
        <li><a href="{{ section.settings.terms_url | default: '/policies/terms-of-service' }}">Terms of Service</a></li>
        <li><a href="{{ section.settings.shipping_url | default: '/policies/shipping-policy' }}">Shipping &amp; Returns</a></li>
      </ul>
    </div>
    <div class="ka-footer__bottom-row">
      <p class="ka-footer__service-line">{{ section.settings.service_line }}</p>
      {%- comment -%}
        Cart build-spec F1 (resolved, final): static text only, no dropdown,
        no {{ localization.available_countries }} loop, no interactive
        component of any kind. This single line is the entire resolution to
        the old Dawn cart's tripled 200-row country/region dropdown bug —
        folded into the one shared global footer per the spec rather than
        forking a cart-specific footer. Do not turn this into a functional
        Markets/localization selector; that is explicitly out of scope here
        (see CLAUDE.md Backlog re: the future currency-converter module).
      {%- endcomment -%}
      <p class="ka-footer__locale">{{ section.settings.locale_line }}</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "settings": [
    { "type": "text",     "id": "brand_name",    "label": "Brand name",  "default": "Karishma Ashita" },
    { "type": "text",     "id": "logo_subline",  "label": "Logo sub-line", "default": "Bridal Couture · Mumbai" },
    { "type": "textarea", "id": "tagline",        "label": "Tagline",     "default": "Bridal couture, handcrafted\nin Mumbai." },
    {
      "type": "header",
      "content": "Social links"
    },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "pinterest_url", "label": "Pinterest URL", "info": "Leave blank to hide the Pinterest link." },
    {
      "type": "header",
      "content": "Contact column"
    },
    { "type": "text",     "id": "email",   "label": "Email address", "default": "info@karishmaashita.com" },
    { "type": "textarea", "id": "address", "label": "Address / shipping note", "default": "Mumbai, India\nComplimentary worldwide shipping" },
    {
      "type": "header",
      "content": "Inner Circle (newsletter column)"
    },
    { "type": "text",     "id": "news_title",       "label": "Column title",   "default": "The Inner Circle" },
    { "type": "textarea", "id": "news_body",        "label": "Supporting line", "default": "Collection previews, styling notes and private trunk show invitations — delivered quietly to your inbox." },
    { "type": "text",     "id": "news_placeholder", "label": "Input placeholder", "default": "Your email address" },
    { "type": "text",     "id": "news_submit",      "label": "Submit button",  "default": "Join" },
    { "type": "text",     "id": "news_success",     "label": "Success message", "default": "Welcome in. You are one of us now." },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    { "type": "text", "id": "service_line", "label": "Service line", "default": "Mumbai · Worldwide Delivery · DHL Express" },
    { "type": "text", "id": "locale_line", "label": "Locale line", "default": "Ships worldwide, priced in INR", "info": "Static text only (Cart build-spec F1, resolved) — no functional country/currency selector. Do not wire this to a Markets/localization picker." },
    {
      "type": "header",
      "content": "Legal links"
    },
    { "type": "url", "id": "privacy_url",  "label": "Privacy Policy URL",       "info": "Defaults to Shopify's /policies/privacy-policy" },
    { "type": "url", "id": "terms_url",    "label": "Terms of Service URL",      "info": "Defaults to /policies/terms-of-service" },
    { "type": "url", "id": "shipping_url", "label": "Shipping & Returns URL",    "info": "Defaults to /policies/shipping-policy" }
  ],
  "presets": [
    { "name": "Footer" }
  ]
}
{% endschema %}
