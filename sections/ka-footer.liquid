{{ 'ka-footer.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  is_about_us — same small reusable check as ka-nav.liquid (Docs/about-
  us-build-spec.md Section 6 H3), drives .is-current on the footer's
  "About Karishma & Ashita" link.
{%- endcomment -%}
{%- assign is_about_us = false -%}
{%- if request.page_type == 'page' and page.handle == 'about-us' -%}{%- assign is_about_us = true -%}{%- endif -%}
{%- comment -%}
  is_visit — same pattern as is_about_us (Docs/store-location-build-
  spec.md Section 3, Section 0), drives .is-current on the footer's
  "Visit Us" link.
{%- endcomment -%}
{%- assign is_visit = false -%}
{%- if request.page_type == 'page' and page.handle == 'visit-the-atelier' -%}{%- assign is_visit = true -%}{%- endif -%}
{%- comment -%}
  is_journal — same pattern as is_about_us/is_visit above (Docs/
  journal-build-spec.md §3 A7 / §7 Flag J9). Drives .is-current on
  the footer's "Journal" link. J9: footer-only per Suraj's explicit
  choice — the primary/top nav (sections/ka-nav.liquid) is
  deliberately NOT touched by this build; do not add a 4th desktop
  nav link here without a separate, explicit sign-off round, per the
  same standing convention that flagged this nav-adjacent change.
{%- endcomment -%}
{%- assign is_journal = false -%}
{%- if request.page_type == 'blog' or request.page_type == 'article' -%}{%- assign is_journal = true -%}{%- endif -%}

<footer class="ka-footer" aria-label="Site footer">
  <div class="ka-footer__top">
    <!-- Column 1: Brand -->
    <div class="ka-footer__brand">
      <span class="ka-footer__logo">{{ section.settings.brand_name }}<small>{{ section.settings.logo_subline }}</small></span>
      <p class="ka-footer__tagline">{{ section.settings.tagline | newline_to_br }}</p>
      <div class="ka-footer__social">
        {%- comment -%}
          Order: Instagram -> YouTube -> Pinterest -> Concierge (browsing
          platforms first, in descending order of the brand's actual
          channel activity per CLAUDE.md, then the pivot from "look" to
          "ask" last). youtube_url follows the exact same blank-check
          pattern as instagram_url/pinterest_url — Docs/search-404-footer-
          build-spec.md §3.2 "YouTube link".
        {%- endcomment -%}
        {% if section.settings.instagram_url != blank %}
          <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener">Instagram</a>
        {% endif %}
        {% if section.settings.youtube_url != blank %}
          <a href="{{ section.settings.youtube_url }}" target="_blank" rel="noopener">YouTube</a>
        {% endif %}
        {% if section.settings.pinterest_url != blank %}
          <a href="{{ section.settings.pinterest_url }}" target="_blank" rel="noopener">Pinterest</a>
        {% endif %}
        <a href="https://wa.me/{{ settings.whatsapp_number }}" target="_blank" rel="noopener">Concierge</a>
      </div>
    </div>

    <!-- Column 2: Collections -->
    <div class="ka-footer__collections">
      <p class="ka-footer__col-title">Collections</p>
      <ul class="ka-footer__links">
        {% for link in linklists['footer-collections'].links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
        {% if linklists['footer-collections'].links.size == 0 %}
          <li><a href="/collections/the-festive-edit">The Festive Edit</a></li>
          <li><a href="/collections/the-bloom-soiree">The Bloom Soirée</a></li>
          <li><a href="/collections/chamak">Chamakk</a></li>
          <li><a href="/collections/barre-oblique">Barre Oblique</a></li>
          <li><a href="/collections/signature-top-sellers">Signature</a></li>
        {% endif %}
      </ul>
    </div>

    <!-- Column 3: Maison -->
    <div class="ka-footer__maison">
      <p class="ka-footer__col-title">Maison</p>
      <ul class="ka-footer__links">
        {% for link in linklists['footer-the-house'].links %}
          <li><a href="{{ link.url }}"{% if is_about_us and link.url contains 'about-us' %} class="is-current"{% elsif is_journal and link.url contains 'blogs' %} class="is-current"{% endif %}>{{ link.title }}</a></li>
        {% endfor %}
        {% if linklists['footer-the-house'].links.size == 0 %}
          <li><a href="/pages/about-us"{% if is_about_us %} class="is-current"{% endif %}>About Karishma &amp; Ashita</a></li>
          <li><a href="/pages/client-diaries">Client Diaries</a></li>
          {%- comment -%}
            Journal link (Docs/journal-build-spec.md §3 A7, §7 Flag J9)
            — added to the fallback list only. If a real
            "footer-the-house" menu is already configured in Shopify
            Admin (Online Store -> Navigation), this fallback never
            renders — the Journal link must also be added there
            manually (a content/Admin step, not a code change).
          {%- endcomment -%}
          {%- comment -%}
            Hardcoded /blogs/news (not a routes.* helper — Shopify has
            no generic "the blog" route since a store can have more
            than one blog resource) per J8: the blog handle stays
            "news", locked, so the 3 already-indexed 2024 article URLs
            keep resolving with zero redirect work.
          {%- endcomment -%}
          <li><a href="/blogs/news"{% if is_journal %} class="is-current"{% endif %}>Journal</a></li>
          <li><a href="/pages/visit-the-atelier"{% if is_visit %} class="is-current"{% endif %}>Visit Us</a></li>
          {%- comment -%}
            "Book an Appointment" — TEMPORARY interim WhatsApp routing,
            same sitewide pattern (Docs/cta-architecture-revision.md
            Round 2, R2-4; extended here for the soft-launch
            /pages/appointments dead-link fix — no Shopify Page with that
            handle exists). data-ka-appt-link is intercepted by the
            sitewide delegated handler in this same file's <script> below.
            href kept as a no-JS fallback / ready slot for a real booking
            flow later.
          {%- endcomment -%}
          <li><a href="/pages/appointments" data-ka-appt-link data-ka-appt-text="Hi, I'd like to book an appointment">Book an Appointment</a></li>
          <li><a href="https://wa.me/{{ settings.whatsapp_number }}" target="_blank" rel="noopener">Concierge</a></li>
          {%- comment -%}
            Press link removed per direct instruction (Docs/search-404-
            footer-build-spec.md §3.2 "Press link removal") — no live
            page exists behind /pages/press yet. Reintroduce when real
            press content exists.
          {%- endcomment -%}
        {% endif %}
      </ul>
    </div>

    <!-- Column 4: Contact -->
    <div class="ka-footer__contact">
      <p class="ka-footer__col-title">Contact</p>
      {%- comment -%}
        ka-footer__contact-items (not ka-footer__contact — that's the
        outer column wrapper above, added per Docs/search-404-footer-
        build-spec.md §T1 for grid-column targeting at the new mobile
        breakpoints; the two must stay distinct classes or the outer
        column would inherit the inner flex-column rule meant only for
        the contact-item list).
      {%- endcomment -%}
      <div class="ka-footer__contact-items">
        {% if settings.whatsapp_number != blank %}
          <p class="ka-footer__contact-item">
            <a href="https://wa.me/{{ settings.whatsapp_number }}">{{ settings.whatsapp_display }}</a>
          </p>
        {% endif %}
        {% if section.settings.email != blank %}
          <p class="ka-footer__contact-item">
            <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
          </p>
        {% endif %}
        <p class="ka-footer__contact-item">{{ section.settings.address | newline_to_br }}</p>
      </div>
    </div>

    <!-- Column 5: Inner Circle (newsletter) -->
    <div class="ka-footer__news">
      <p class="ka-footer__col-title">{{ section.settings.news_title }}</p>
      <p>{{ section.settings.news_body }}</p>
      {%- comment -%}
        Defaults to Shopify native customer email subscribe. To swap for
        Klaviyo, replace this {% form 'customer' %} block with the embed.
      {%- endcomment -%}
      {% form 'customer', class: 'ka-footer__news-form' %}
        {% if form.posted_successfully? %}
          <p class="ka-footer__news-success">{{ section.settings.news_success }}</p>
        {% else %}
          <input type="hidden" name="contact[tags]" value="newsletter,ka-correspondence" />
          <input
            type="email"
            name="contact[email]"
            class="ka-footer__news-input"
            placeholder="{{ section.settings.news_placeholder }}"
            aria-label="{{ section.settings.news_placeholder }}"
            required
          />
          <button type="submit" class="ka-footer__news-submit">{{ section.settings.news_submit }}</button>
        {% endif %}
      {% endform %}
    </div>
  </div>

  {%- comment -%}
    Bottom bar — SIMPLIFIED to one row (copyright + legal), Docs/search-
    404-footer-build-spec.md §3.2. The old service_line + locale_line
    row is removed outright, not relocated — its one non-redundant fact
    (DHL Express) is folded into the Contact column's address setting
    above instead, so the logistics story is told exactly once, in the
    one place a visitor actually looks for it (spec §3.1/§3.2 "Copy fix").
    Do not re-add a country/currency selector here — Cart build-spec F1
    deliberately kept this bar static-text-only; that reasoning still
    applies, there's just no second logistics line to carry it anymore.
  {%- endcomment -%}
  <div class="ka-footer__bottom">
    <p class="ka-footer__copy">&copy; {{ 'now' | date: '%Y' }} {{ section.settings.brand_name }}, a brand of {{ section.settings.legal_entity_name }}. All rights reserved.</p>
    <ul class="ka-footer__legal">
      <li><a href="{{ section.settings.privacy_url | default: '/policies/privacy-policy' }}">Privacy Policy</a></li>
      <li><a href="{{ section.settings.terms_url | default: '/policies/terms-of-service' }}">Terms of Service</a></li>
      <li><a href="{{ section.settings.shipping_url | default: '/policies/shipping-policy' }}">Shipping &amp; Returns</a></li>
    </ul>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "settings": [
    { "type": "text",     "id": "brand_name",    "label": "Brand name",  "default": "Karishma Ashita" },
    { "type": "text",     "id": "logo_subline",  "label": "Logo sub-line", "default": "Bridal Couture · Mumbai" },
    { "type": "textarea", "id": "tagline",        "label": "Tagline",     "default": "Bridal couture, handcrafted\nin Mumbai." },
    {
      "type": "header",
      "content": "Social links"
    },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL", "info": "Leave blank to hide the Instagram link." },
    { "type": "url", "id": "youtube_url",   "label": "YouTube URL",   "info": "Leave blank to hide the YouTube link." },
    { "type": "url", "id": "pinterest_url", "label": "Pinterest URL", "info": "Leave blank to hide the Pinterest link." },
    {
      "type": "header",
      "content": "Contact column"
    },
    {
      "type": "paragraph",
      "content": "This address block is the site's single authoritative logistics line (Docs/search-404-footer-build-spec.md §3.2) — Mumbai + worldwide shipping is stated here once, not repeated elsewhere in the footer."
    },
    { "type": "text",     "id": "email",   "label": "Email address", "default": "info@karishmaashita.com" },
    { "type": "textarea", "id": "address", "label": "Address / shipping note", "default": "Mumbai, India\nComplimentary worldwide shipping via DHL Express" },
    {
      "type": "header",
      "content": "Inner Circle (newsletter column)"
    },
    { "type": "text",     "id": "news_title",       "label": "Column title",   "default": "The Inner Circle" },
    { "type": "textarea", "id": "news_body",        "label": "Supporting line", "default": "Collection previews, styling notes and private trunk show invitations — delivered quietly to your inbox." },
    { "type": "text",     "id": "news_placeholder", "label": "Input placeholder", "default": "Your email address" },
    { "type": "text",     "id": "news_submit",      "label": "Submit button",  "default": "Join" },
    { "type": "text",     "id": "news_success",     "label": "Success message", "default": "Welcome in. You are one of us now." },
    {
      "type": "header",
      "content": "Legal links"
    },
    { "type": "text", "id": "legal_entity_name", "label": "Legal entity name", "default": "Peekay International Ltd.", "info": "Appended to the bottom-bar copyright line: \"© {year} [Brand name], a brand of [Legal entity name]. All rights reserved.\"" },
    { "type": "url", "id": "privacy_url",  "label": "Privacy Policy URL",       "info": "Defaults to Shopify's /policies/privacy-policy" },
    { "type": "url", "id": "terms_url",    "label": "Terms of Service URL",      "info": "Defaults to /policies/terms-of-service" },
    { "type": "url", "id": "shipping_url", "label": "Shipping & Returns URL",    "info": "Defaults to /policies/shipping-policy" }
  ],
  "presets": [
    { "name": "Footer" }
  ]
}
{% endschema %}
