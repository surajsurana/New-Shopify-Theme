{{ 'ka-appointment.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Both appointment CTAs — TEMPORARY interim WhatsApp routing, same pattern
  used sitewide (Docs/cta-architecture-revision.md Round 2, R2-4; extended
  to this section as part of the soft-launch /pages/appointments dead-link
  fix, since no Shopify Page with that handle exists). Each button carries
  data-ka-appt-link, intercepted by the sitewide delegated click handler in
  ka-nav.liquid, which opens https://wa.me/{{ settings.whatsapp_number }}
  with a pre-filled enquiry distinguishing in-store vs. virtual so Suraj's
  team knows which was requested. cta_instore_url / cta_virtual_url are kept
  as the real hrefs (no-JS fallback + ready slot for a real booking flow
  later) — Suraj can still override them via section settings, but until a
  real booking system exists, JS always reroutes to WhatsApp regardless of
  what's configured here. Remove data-ka-appt-link from a button once its
  real booking destination is live.
{%- endcomment -%}

<section class="ka-appointment" aria-label="Book a styling appointment">
  <div class="ka-appointment__bg reveal-img">
    {% if section.settings.image != blank %}
      <img
        src="{{ section.settings.image | image_url: width: 1600 }}"
        alt="{{ section.settings.image.alt | escape | default: 'K&A atelier — styling appointment' }}"
        loading="lazy"
        width="1600"
        height="1067"
        class="img-filter-appointment"
      />
    {% else %}
      {%- comment -%}
        fallback_image_filename — generalised (Docs/about-us-build-spec.md
        Section 6 H2) so this shared section can be reused on more than one
        page with a different no-image fallback (e.g. about-closing-cta.jpg
        on the About page vs. appointment-bg.jpg on the homepage) without
        an image_picker selection, since neither page currently has admin
        access to upload the real photo into Shopify Files. Once a real
        Files-library image is selected via section.settings.image, this
        fallback is never used.
      {%- endcomment -%}
      <img
        src="{{ section.settings.fallback_image_filename | default: 'appointment-bg.jpg' | asset_url }}"
        alt="K&A atelier — styling appointment"
        loading="lazy"
        width="1600"
        height="1067"
        class="img-filter-appointment"
      />
    {% endif %}
  </div>
  <div class="ka-appointment__overlay"></div>
  <div class="ka-appointment__content">
    <p class="eyebrow eyebrow--on-dark ka-appointment__eyebrow reveal">{{ section.settings.eyebrow }}</p>
    <h2 class="ka-appointment__title reveal reveal-delay-1">{{ section.settings.title | newline_to_br }}</h2>
    <p class="ka-appointment__body reveal reveal-delay-2">{{ section.settings.body }}</p>
    <div class="ka-appointment__options reveal reveal-delay-3">
      <a
        href="{{ section.settings.cta_instore_url | default: '/pages/appointments' }}"
        class="btn-outline-white"
        data-ka-appt-link
        data-ka-appt-text="{{ section.settings.cta_instore_wa_text | default: "Hi, I'd like to book an in-store appointment" }}"
      >
        {{ section.settings.cta_instore_label }}
      </a>
      <span class="ka-appointment__divider">or</span>
      <a
        href="{{ section.settings.cta_virtual_url | default: '/pages/appointments' }}"
        class="btn-outline-white"
        data-ka-appt-link
        data-ka-appt-text="{{ section.settings.cta_virtual_wa_text | default: "Hi, I'd like to book a virtual styling session" }}"
      >
        {{ section.settings.cta_virtual_label }}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Appointment CTA",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image",    "label": "Background image" },
    {
      "type": "text",
      "id": "fallback_image_filename",
      "label": "Fallback image (theme asset filename)",
      "default": "appointment-bg.jpg",
      "info": "Used only when no Background image is selected above. Advanced — must exactly match a filename already in the theme's Assets folder (e.g. about-closing-cta.jpg). Leave as default unless reusing this section on a page that needs a different placeholder."
    },
    { "type": "text",         "id": "eyebrow",  "label": "Eyebrow",   "default": "The Atelier" },
    { "type": "text",         "id": "title",    "label": "Title",     "default": "Begin with a\nConversation." },
    { "type": "textarea",     "id": "body",     "label": "Body text", "default": "Every K&A bride begins with a private styling session — in our Mumbai atelier or virtually, wherever in the world you are. We listen before we design." },
    {
      "type": "header",
      "content": "CTAs"
    },
    { "type": "text", "id": "cta_instore_label", "label": "In-store CTA label",   "default": "Book In-Store Appointment" },
    {
      "type": "url",
      "id": "cta_instore_url",
      "label": "In-store CTA URL",
      "info": "Defaults to /pages/appointments. Update once booking system is confirmed."
    },
    {
      "type": "text",
      "id": "cta_instore_wa_text",
      "label": "In-store CTA — WhatsApp pre-fill text",
      "default": "Hi, I'd like to book an in-store appointment",
      "info": "Added 2026-07-22 (FAQ build) so this shared component can support non-appointment CTA copy (e.g. FAQ's \"Ask Our Styling Concierge\" leading button) without the WhatsApp message text reading as a mismatched \"book an appointment\" request. Purely additive — every page using this section before this change is unaffected, since the default here matches the value that used to be hardcoded."
    },
    { "type": "text", "id": "cta_virtual_label", "label": "Virtual CTA label",   "default": "Book Virtual Styling Session" },
    {
      "type": "url",
      "id": "cta_virtual_url",
      "label": "Virtual CTA URL",
      "info": "Defaults to /pages/appointments. Can be a Calendly/Typeform link or WhatsApp pre-fill."
    },
    {
      "type": "text",
      "id": "cta_virtual_wa_text",
      "label": "Virtual CTA — WhatsApp pre-fill text",
      "default": "Hi, I'd like to book a virtual styling session",
      "info": "Same purpose/reasoning as the in-store field above."
    }
  ],
  "presets": [
    { "name": "Appointment CTA" }
  ]
}
{% endschema %}
