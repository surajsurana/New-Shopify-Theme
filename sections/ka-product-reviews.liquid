{{ 'ka-product-reviews.css' | asset_url | stylesheet_tag }}

<section class="ka-voice" id="reviews">
  <div class="reveal">
    <div class="ka-voice__glogo"><span class="b">G</span><span class="r">o</span><span class="y">o</span><span class="b">g</span><span class="g2">l</span><span class="r">e</span><span style="color:#A89E8E">&nbsp;Reviews</span></div>
    <div class="ka-voice__summary">
      <div class="ka-voice__score">{{ section.settings.rating_score }}</div>
      <div style="text-align:left">
        <div class="ka-voice__summary"><span class="ka-voice__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span></div>
        <div class="ka-voice__cnt">Based on {{ section.settings.rating_count }} reviews</div>
      </div>
    </div>
    <div class="ka-voice__head">{{ section.settings.heading }}</div>

    <div class="ka-rev-grid">
      {%- for block in section.blocks -%}
        <div class="ka-rev" {{ block.shopify_attributes }}>
          <div class="ka-rev__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>{{ block.settings.quote }}</p>
          <div class="ka-rev__who">
            <div class="ka-rev__av">{{ block.settings.reviewer_name | slice: 0 }}</div>
            <div>
              <div class="ka-rev__nm">{{ block.settings.reviewer_name }}</div>
              <div class="ka-rev__src">{{ block.settings.source }}</div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.google_url != blank -%}
      <div class="ka-voice__more"><a href="{{ section.settings.google_url }}" target="_blank" rel="noopener">Read all {{ section.settings.rating_count }} reviews on Google &rarr;</a></div>
    {%- endif -%}
    {%- if section.settings.disclaimer != blank -%}
      <div class="ka-voice__note">{{ section.settings.disclaimer }}</div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product Reviews",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "rating_score", "label": "Aggregate score", "default": "4.9" },
    { "type": "text", "id": "rating_count", "label": "Review count", "default": "217" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved by brides & their families, across the world." },
    { "type": "url",  "id": "google_url", "label": "Google reviews URL", "info": "Real Google Business Profile review link. Leave blank to hide the link." },
    { "type": "text", "id": "disclaimer", "label": "Disclaimer note", "default": "Sample reviews shown — to be connected to the live Google profile", "info": "REMOVE before launch once real reviews are wired in." }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "limit": 6,
      "settings": [
        { "type": "textarea", "id": "quote",         "label": "Quote" },
        { "type": "text",     "id": "reviewer_name", "label": "Reviewer name" },
        { "type": "text",     "id": "source",        "label": "Source", "default": "via Google" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Reviews",
      "blocks": [
        { "type": "review", "settings": { "quote": "I felt like the piece was made for my body — because it was. Three fittings over video from London, and it arrived perfect. I have never felt more myself at a wedding.", "reviewer_name": "Aisha R.", "source": "via Google" } },
        { "type": "review", "settings": { "quote": "I am the bride's mother and was nervous about ordering online. The concierge held my hand through every step. The embroidery in person is breathtaking.", "reviewer_name": "Meera S.", "source": "via Google" } },
        { "type": "review", "settings": { "quote": "Wore the corset drape to my sister's reception. Every single person asked where it was from. The fit was flawless and the fabric moves like water.", "reviewer_name": "Kavya N.", "source": "via Google" } }
      ]
    }
  ]
}
{% endschema %}
