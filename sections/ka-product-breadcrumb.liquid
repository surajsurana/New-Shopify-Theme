{{ 'ka-product-breadcrumb.css' | asset_url | stylesheet_tag }}

{%- assign primary_collection = product.collections.first -%}

<nav class="ka-pb" aria-label="Breadcrumb">
  <div class="ka-pb__inner">
    <a href="{{ routes.root_url }}">Home</a>
    <span class="ka-pb__sep" aria-hidden="true">/</span>
    {%- if primary_collection -%}
      <a href="{{ primary_collection.url }}">{{ primary_collection.title }}</a>
      <span class="ka-pb__sep" aria-hidden="true">/</span>
    {%- endif -%}
    <span class="ka-pb__current">{{ product.title }}</span>
  </div>
</nav>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ routes.root_url | prepend: shop.url }}"
    }
    {%- if primary_collection -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ primary_collection.title | json }},
      "item": "{{ primary_collection.url | prepend: shop.url }}"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ product.title | json }},
      "item": "{{ product.url | prepend: shop.url }}"
    }
    {%- else -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": {{ product.title | json }},
      "item": "{{ product.url | prepend: shop.url }}"
    }
    {%- endif -%}
  ]
}
</script>

{% schema %}
{
  "name": "Product Breadcrumb",
  "tag": "section",
  "settings": [],
  "presets": [{ "name": "Product Breadcrumb" }]
}
{% endschema %}
