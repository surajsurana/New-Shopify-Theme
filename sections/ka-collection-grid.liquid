{{ 'ka-collection-grid.css' | asset_url | stylesheet_tag }}
<script src="{{ 'ka-collection.js' | asset_url }}" defer></script>

{%- comment -%}
  K&A Collection Grid + Editorial Insert + Load More
  Spec: Docs/collection-build-spec.md, Section 2 ("Section 6 — Product Grid",
  "Section 7 — Editorial Insert", "Section 8 — Load More"), F5, F6, F7, F10,
  CD Notes 1 and 3.

  One continuous {% paginate %} loop (real Shopify pagination, not two hardcoded
  static grids as in the prototype). Editorial insert is injected at a fixed
  forloop.index position (after the 6th product) and ONLY on page 1 of the
  paginated set, per F6 and CD Note 3 — it must appear exactly once, never repeat
  across pages and never vanish.

  Pagination mechanism (F7): AJAX "Load More" via the Section Rendering API
  (?section_id={{ section.id }}&page=N), implemented in assets/ka-collection.js.
  Progressive-enhancement fallback: the button is a real <a href="{{ paginate.next.url }}">
  so it works with JS disabled (traditional pagination), and ka-collection.js
  intercepts the click to fetch + append instead when JS is available.

  Round 2 (Docs/cta-architecture-revision.md) — SUPERSEDES the note that used
  to live here. "Enquire on WhatsApp" is no longer the only conversion
  affordance: each card image is now a real link to the PDP, plus a working
  "+ Add to Bag" quick-add veil button (replacing the WhatsApp veil link)
  and an always-visible "View Details →" line. WhatsApp/concierge remains
  available sitewide (header, footer, floating button) but is no longer
  this grid's only path to a sale — see CLAUDE.md's "buy path primary"
  standing principle.

  OPEN DECISION (resolved by Technical Director, this build) — multi-variant
  quick-add behaviour: quick-add adds product.selected_or_first_available_variant
  (Shopify's own standard "default/first available variant" concept, the same
  one Dawn's native quick-add uses) rather than prompting for a size inline or
  forcing a click-through to the PDP first. Reasoning: the grid is a browsing/
  discovery context, not a sizing moment — surfacing a "Select Size" picker
  here would add friction exactly where CLAUDE.md says not to. The size can
  still be changed afterwards from the Bag, and the PDP remains one click away
  via the image link / "View Details" for anyone who wants to choose first.
{%- endcomment -%}

{% liquid
  assign per_page = section.settings.products_per_page | default: 9
  assign insert_after_index = section.settings.insert_after_index | default: 6
%}

{%- if collection.products_count == 0 -%}
  <div class="ka-collection-empty">
    <p class="eyebrow eyebrow--muted">Coming Soon</p>
    <h2 class="ka-collection-empty__title">{{ collection.title }}</h2>
    <p class="ka-collection-empty__body">This collection is being prepared with great care. Be among the first to see the pieces when they arrive.</p>
    <div class="ka-collection-empty__actions">
      <a href="https://wa.me/{{ settings.whatsapp_number }}?text=Hi%2C%20I%27d%20love%20to%20be%20the%20first%20to%20see%20{{ collection.title | url_encode }}" class="btn-dark" target="_blank" rel="noopener">Be the First to Know</a>
      <a href="/collections" class="btn-outline-rose">Browse All Collections</a>
    </div>
  </div>
{%- else -%}

{% paginate collection.products by per_page %}
  <div class="ka-product-grid" id="ka-product-grid-{{ section.id }}" data-ka-product-grid>
    {% for product in collection.products %}
      {%- assign quickadd_variant = product.selected_or_first_available_variant -%}
      <div class="ka-p-card reveal-img">
        <div class="ka-p-card__image">
          {%- comment -%}
            Sibling (not nested) absolutely-positioned layers: the image-link
            anchor and the quick-add veil button both live inside this
            non-anchor wrapper div, so neither is ever an <a> nested inside
            another <a> (invalid HTML). z-index keeps the veil's button
            clickable above the link on hover.
          {%- endcomment -%}
          <a href="{{ product.url }}" class="ka-p-card__image-link" aria-label="View {{ product.title | escape }}"></a>
          {% if product.featured_image %}
            <img
              src="{{ product.featured_image | image_url: width: 800 }}"
              alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
              loading="lazy"
              width="800"
              height="1067"
              class="img-filter-coll-page"
            />
          {% else %}
            <div style="background: var(--c-smoke); width:100%; height:100%;"></div>
          {% endif %}
          {% if product.tags contains 'made-to-order' or product.tags contains 'Made to Order' %}
            <span class="ka-p-card__badge">Made to Order</span>
          {% endif %}
          <div class="ka-p-card__veil">
            <button
              type="button"
              class="ka-p-card__veil-quickadd{% if quickadd_variant == nil %} ka-p-card__veil-quickadd--oos{% endif %}"
              data-ka-quickadd
              data-variant-id="{{ quickadd_variant.id }}"
              data-product-title="{{ product.title | escape }}"
              {% if quickadd_variant == nil %}aria-disabled="true"{% endif %}
            >{% if quickadd_variant == nil %}Sold Out{% else %}+ Add to Bag{% endif %}</button>
          </div>
        </div>
        <div class="ka-p-card__info">
          <h3 class="ka-p-card__name"><a href="{{ product.url }}">{{ product.title }}</a></h3>
          {% if product.metafields.custom.fabric_description != blank %}
            <p class="ka-p-card__fabric">{{ product.metafields.custom.fabric_description }}</p>
          {% endif %}
          <p class="ka-p-card__price"><span data-price="{{ product.price }}">{{ product.price | money_without_trailing_zeros | replace: 'Rs.', '₹' }}</span> <span>onward</span></p>
          <a href="{{ product.url }}" class="ka-p-card__action">View Details &rarr;</a>
        </div>
      </div>

      {% if forloop.index == insert_after_index and paginate.current_page == 1 %}
        <div class="ka-editorial-insert">
          <div class="ka-editorial-insert__frame reveal-img">
            {% if section.settings.insert_image != blank %}
              <img
                src="{{ section.settings.insert_image | image_url: width: 1800 }}"
                alt="{{ section.settings.insert_image.alt | escape | default: collection.title }}"
                loading="lazy"
                width="1800"
                height="1000"
                class="img-filter-coll-page-dark"
              />
            {% else %}
              {%- assign handle_lower = collection.handle | downcase -%}
              {%- case handle_lower -%}
                {%- when 'first-love' -%}
                  <img src="{{ 'first-love-editorial.jpg' | asset_url }}" alt="{{ collection.title }}" loading="lazy" width="1800" height="1000" class="img-filter-coll-page-dark" />
                {%- when 'the-bloom-soiree' -%}
                  <img src="{{ 'bloom-soiree-hero.jpg' | asset_url }}" alt="{{ collection.title }}" loading="lazy" width="1800" height="1000" class="img-filter-coll-page-dark" />
                {%- when 'the-festive-edit' -%}
                  {%- comment -%} Interim — no suitable editorial insert for Festive Edit yet. {%- endcomment -%}
                  <img src="{{ 'celebrity-editorial.jpg' | asset_url }}" alt="{{ collection.title }}" loading="lazy" width="1800" height="1000" class="img-filter-coll-page-dark" />
                {%- when 'chamak' -%}
                  <img src="{{ 'chamak-insert.jpg' | asset_url }}" alt="{{ collection.title }}" loading="lazy" width="1800" height="1000" class="img-filter-coll-page-dark" />
                {%- when 'barre-oblique' -%}
                  <img src="{{ 'barre-insert.jpg' | asset_url }}" alt="{{ collection.title }}" loading="lazy" width="1800" height="1000" class="img-filter-coll-page-dark" />
                {%- when 'wedding-festive', 'the-wedding-festive-collection-22' -%}
                  <img src="{{ 'wedding-festive-insert.jpg' | asset_url }}" alt="{{ collection.title }}" loading="lazy" width="1800" height="1000" class="img-filter-coll-page-dark" />
                {%- when 'bestsellers' -%}
                  <img src="{{ 'bestsellers-insert.jpg' | asset_url }}" alt="{{ collection.title }}" loading="lazy" width="1800" height="1000" class="img-filter-coll-page-dark" />
                {%- else -%}
                  <div style="background: var(--c-charcoal-2); width:100%; height:100%;"></div>
              {%- endcase -%}
            {% endif %}
            <div class="ka-editorial-insert__overlay"></div>
            <p class="ka-editorial-insert__caption reveal">
              {{ collection.metafields.custom.editorial_caption | default: "Caption pending — Creative Director, see collection-build-spec.md §4" }}
            </p>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="ka-load-more reveal" data-ka-load-more
    data-section-id="{{ section.id }}"
    data-current-page="{{ paginate.current_page }}"
    data-pages="{{ paginate.pages }}"
    data-items="{{ paginate.items }}"
    data-per-page="{{ per_page }}"
    data-next-url="{% if paginate.next %}{{ paginate.next.url }}{% endif %}"
  >
    {% if paginate.next %}
      <a href="{{ paginate.next.url }}" class="btn-outline-rose" data-ka-load-more-btn>View More of the Collection</a>
    {% endif %}
    <span class="ka-load-more__count" data-ka-load-more-count>
      Showing {{ paginate.current_offset | plus: collection.products.size }} of {{ paginate.items }} pieces
    </span>
  </div>
{% endpaginate %}
{%- endif -%}

<!-- Toast: shared component, CSS in ka-base.css, JS in ka-theme.js (window.kaShowToast).
     Rendered once here for quick-add confirmations on this page. -->
<div class="ka-toast" id="kaToast" role="status" aria-live="polite">
  <span class="ka-toast__mark" aria-hidden="true">&#10022;</span>
  <div class="ka-toast__body">
    <div class="ka-toast__title">Added to Your Bag</div>
    <div class="ka-toast__sub" id="kaToastSub">&nbsp;</div>
  </div>
  <a class="ka-toast__action" href="{{ routes.cart_url }}">View Bag &rarr;</a>
</div>

{% schema %}
{
  "name": "Collection Grid",
  "tag": "div",
  "class": "ka-collection-grid-section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 3,
      "max": 24,
      "step": 3,
      "default": 9
    },
    {
      "type": "range",
      "id": "insert_after_index",
      "label": "Insert editorial image after Nth product (page 1 only)",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "image_picker",
      "id": "insert_image",
      "label": "Editorial insert image",
      "info": "Pre-populate with the placeholder assigned in Docs/collection-build-spec.md Section 5 until real capsule photography exists."
    },
    {
      "type": "paragraph",
      "content": "Editorial insert caption text is pulled from the collection.metafields.custom.editorial_caption metafield, not a setting here, so it can vary per collection without a code change."
    }
  ],
  "presets": [
    { "name": "Collection Grid" }
  ]
}
{% endschema %}
