{{ 'ka-product-main.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign wa = settings.whatsapp_number
  # NOTE — appointment_url (schema setting below) is currently DORMANT.
  # Round 2 (Docs/cta-architecture-revision.md) routes "Book an Appointment"
  # through WhatsApp instead, as a TEMPORARY measure pending a real
  # booking flow/calendar. The setting is left in the schema (not removed)
  # so a future real booking flow has a ready slot to wire into — see
  # data-ka-appt-link handling in ka-product.js.
  assign appt_url = section.settings.appointment_url | default: '/pages/appointments'
  assign price = product.price | money_without_trailing_zeros | replace: 'Rs.', '₹'

  # Pre-filled WhatsApp enquiry with product context (F2)
  assign wa_text = 'Hi, I' | append: '%27' | append: 'd like to enquire about the ' | append: product.title
  assign wa_text_enc = wa_text | url_param_escape
  assign wa_enquire = 'https://wa.me/' | append: wa | append: '?text=' | append: wa_text_enc

  # Detect the Size option (case-insensitive) for variant-driven selection
  assign size_option = null
  for opt in product.options_with_values
    assign opt_down = opt.name | downcase
    if opt_down contains 'size'
      assign size_option = opt
    endif
  endfor

  # Per-product metafields (custom namespace) with graceful fallbacks
  assign poem = product.metafields.custom.poem_tagline
  assign lead_time = product.metafields.custom.lead_time | default: section.settings.default_lead_time
  assign mf_atelier = product.metafields.custom.atelier_process
  # custom.fabric is a single_line_text_field (e.g. "Georgette") — shown as a label in the accordion
  assign mf_fabric = product.metafields.custom.fabric
  # custom.embroidery is a multi_line_text_field — per-product embroidery description; no generic fallback claim if blank
  assign mf_embroidery = product.metafields.custom.embroidery
  # custom.size_chart and custom.shipping are page_reference metafields — use .value to get the Page object, then .content for body HTML
  assign mf_sizefit = product.metafields.custom.size_chart.value
  assign mf_delivery = product.metafields.custom.shipping.value
-%}

<section class="ka-product" id="ka-product">

  <!-- ── Gallery: sticky thumbnail rail + stage ── -->
  <div class="ka-media" id="ka-media">
    <div class="ka-thumbs" id="ka-thumbs">
      {%- for image in product.images -%}
        <button
          type="button"
          class="ka-thumb{% if forloop.first %} active{% endif %}"
          data-full="{{ image | image_url: width: 1400 }}"
          data-tag="{{ image.alt | escape }}"
          aria-label="View image {{ forloop.index }}"
          style="background-image:url('{{ image | image_url: width: 200 }}');"
        ></button>
      {%- else -%}
        <button type="button" class="ka-thumb active ka-thumb--ph" aria-label="Product image"></button>
      {%- endfor -%}
    </div>

    {%- assign first_image = product.featured_image -%}
    <div
      class="ka-stage{% unless first_image %} ka-stage--ph{% endunless %}"
      id="ka-stage"
      {% if first_image %}style="background-image:url('{{ first_image | image_url: width: 1400 }}');"{% endif %}
    >
      {%- if first_image and first_image.alt != blank -%}
        <span class="ka-stage__tag" id="ka-stage-tag">{{ first_image.alt | escape }}</span>
      {%- else -%}
        <span class="ka-stage__tag" id="ka-stage-tag" style="opacity:0;"></span>
      {%- endif -%}
      <span class="ka-stage__idx" id="ka-stage-idx">01 / {% if product.images.size > 0 %}{{ product.images.size | prepend: '0' | slice: -2, 2 }}{% else %}01{% endif %}</span>
      <span class="ka-stage__zoom" aria-hidden="true">&#10530; Zoom</span>
    </div>
  </div>

  <!-- ── Info panel ── -->
  <div class="ka-info-wrap">
    <div class="ka-panel">
      {%- if product.collections.first -%}
        <a href="{{ product.collections.first.url }}" class="eyebrow ka-collection-tag">{{ product.collections.first.title }}</a>
      {%- endif -%}

      <h1 class="ka-p-title">{{ product.title }}</h1>

      {%- if poem != blank -%}
        <p class="ka-p-poem">{{ poem }}</p>
      {%- endif -%}

      <button type="button" class="ka-grating" id="ka-grating" title="Read our Google reviews">
        <span class="ka-grating__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <span class="ka-grating__tx"><b>{{ section.settings.rating_score }}</b> · {{ section.settings.rating_count }} reviews on</span>
        <span class="ka-glogo"><span class="b">G</span><span class="r">o</span><span class="y">o</span><span class="b">g</span><span class="g2">l</span><span class="r">e</span></span>
      </button>

      <div class="ka-p-price-row">
        <div class="ka-p-price" data-price="{{ product.price }}">{{ price }}</div>
        <div class="ka-p-tax">Taxes included</div>
      </div>
      <div class="ka-p-made">Made to measure · Crafted to order in {{ lead_time }}</div>

      <!-- SIZE + BESPOKE (mapped to Shopify variant option) -->
      <div class="ka-opt-head">
        <span class="ka-opt-label">Select Your Size</span>
        <button type="button" class="ka-btn-line" data-open-acc="size">Size &amp; Fit Guide</button>
      </div>

      <div class="ka-size-grid" id="ka-sizes">
        {%- if size_option -%}
          {%- for value in size_option.values -%}
            {%- assign v_down = value | downcase -%}
            {%- unless v_down contains 'measure' or v_down contains 'bespoke' or v_down contains 'custom' -%}
              {%- comment -%}
                Find the matching variant for this size value so the button
                can carry a real numeric Shopify variant ID — /cart/add.js
                needs an id, not an option label. If the product has other
                option dimensions (e.g. Colour) this takes the first
                available variant matching this size; a single-option
                "Size only" product (the common case here) matches exactly.
              {%- endcomment -%}
              {%- assign matched_variant = null -%}
              {%- for v in product.variants -%}
                {%- if v.available and matched_variant == null -%}
                  {%- for opt_val in v.options -%}
                    {%- if opt_val == value -%}
                      {%- assign matched_variant = v -%}
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
              {%- endfor -%}
              {%- unless matched_variant -%}
                {%- for v in product.variants -%}
                  {%- if matched_variant == null -%}
                    {%- for opt_val in v.options -%}
                      {%- if opt_val == value -%}
                        {%- assign matched_variant = v -%}
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endunless -%}
              <button
                type="button"
                class="ka-size{% if matched_variant == null or matched_variant.available == false %} ka-size--oos{% endif %}"
                data-value="{{ value | escape }}"
                data-variant-id="{{ matched_variant.id }}"
                {% if matched_variant == null or matched_variant.available == false %}aria-disabled="true"{% endif %}
              >{{ value }}</button>
            {%- endunless -%}
          {%- endfor -%}
        {%- else -%}
          {%- comment -%}
            Fallback when no Size option exists yet on the product — there
            is no real variant to map, so these render disabled rather than
            pretending to be addable. A product launched without a Size
            option is a content gap, not something JS can paper over.
          {%- endcomment -%}
          <button type="button" class="ka-size ka-size--oos" data-value="XS" data-variant-id="" aria-disabled="true">XS</button>
          <button type="button" class="ka-size ka-size--oos" data-value="S" data-variant-id="" aria-disabled="true">S</button>
          <button type="button" class="ka-size ka-size--oos" data-value="M" data-variant-id="" aria-disabled="true">M</button>
          <button type="button" class="ka-size ka-size--oos" data-value="L" data-variant-id="" aria-disabled="true">L</button>
          <button type="button" class="ka-size ka-size--oos" data-value="XL" data-variant-id="" aria-disabled="true">XL</button>
        {%- endif -%}
      </div>

      {%- comment -%}
        Find the "Made to my measurements" / bespoke variant (any size option
        value that contains 'measure' or 'bespoke') so the button can carry
        a real Shopify variant ID — this lets Add to Bag do a literal cart add
        instead of routing to WhatsApp. If no such variant exists on the product,
        the button renders without data-variant-id and ka-product.js gracefully
        falls back to the WhatsApp flow.
      {%- endcomment -%}
      {%- assign bespoke_variant = null -%}
      {%- for v in product.variants -%}
        {%- if bespoke_variant == null -%}
          {%- for opt_val in v.options -%}
            {%- assign ov_down = opt_val | downcase -%}
            {%- if ov_down contains 'measure' or ov_down contains 'bespoke' -%}
              {%- assign bespoke_variant = v -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if bespoke_variant -%}
        {%- comment -%}Real MTM variant — add to cart directly, no special properties needed.{%- endcomment -%}
        <button class="ka-bespoke" id="ka-bespoke" type="button" data-variant-id="{{ bespoke_variant.id }}">
      {%- else -%}
        {%- comment -%}No dedicated MTM variant — use first available variant as fallback.
          ka-product.js will add "Size: Made to my measurements" as a line-item property
          so the order reads correctly for the style advisor.{%- endcomment -%}
        <button class="ka-bespoke" id="ka-bespoke" type="button"
          data-variant-id="{{ product.selected_or_first_available_variant.id }}"
          data-mtm-fallback="true">
      {%- endif -%}
        <span class="ka-bespoke__dot" aria-hidden="true"></span>
        <span class="ka-bespoke__k">Made to my measurements</span>
        <span class="ka-bespoke__s">Recommended</span>
      </button>

      <!-- MADE-TO-MEASURE reveal -->
      <div class="ka-mtm" id="ka-mtm">
        <div class="ka-mtm__inner">
          <h4>How Your Piece Comes to Life</h4>
          <ul class="ka-mtm__steps">
            <li>Place your order — no measurements needed yet. Your personal style advisor will be in touch within 24 hours to begin. Already have your measurements? Add them to the order notes at checkout and we will take it from there.</li>
            <li>Confirm your fit with your advisor — over WhatsApp, on a virtual call, or in our Mumbai atelier. We work at your pace, entirely.</li>
            <li>Our atelier cuts, drapes and hand-embroiders your piece to your exact measurements. Every element made for you alone.</li>
          </ul>
          <p class="ka-mtm__foot">Your piece is then pressed, quality-checked and delivered worldwide in {{ lead_time }}.</p>
          <button type="button" class="ka-mtm__link" data-open-acc="size">View the measurement guide &rarr;</button>
        </div>
      </div>

      <!--
        CTAs — Round 2 rebuild (Docs/cta-architecture-revision.md).
        Real Add to Bag via Ajax Cart API, gated on a Size selection (or
        the bespoke "Made to my measurements" path, which routes to
        WhatsApp/appointment instead of a literal cart add — see the
        OPEN DECISION note below). "Book an Appointment" is TEMPORARY:
        it routes to the same WhatsApp concierge destination as the
        Concierge button until a real appointment-booking flow/calendar
        exists. Do not let this silently become permanent.

        OPEN DECISION (resolved by Technical Director, this build):
        "Made to my measurements" does NOT map to a literal cart-line
        add. There is no fixed variant/SKU that represents "bespoke" —
        the prototype's own MTM panel describes a human-mediated
        measurement-confirmation step before production starts. Forcing
        it into /cart/add.js against a placeholder variant would create
        a paid cart line with no confirmed fit yet, which is friction in
        the wrong direction (a customer paying before the order is even
        specced). So: selecting bespoke + clicking "Add to Bag" routes
        to the same WhatsApp/appointment flow as "Book an Appointment",
        with on-page copy explaining why (see ka-product.js addToBag()).
        Sized variants still add to the real cart with zero friction —
        the common case stays a true one-click buy path, per CLAUDE.md's
        "buy path primary" principle.
      -->
      <div class="ka-cta-stack">
        <button type="button" class="ka-btn ka-btn--bag" id="ka-bag-btn" data-ka-add-to-bag aria-disabled="true">Add to Bag</button>
        <p class="ka-size-required-hint" id="ka-size-hint">Please select a size, or choose Made to my measurements.</p>
        <button type="button" class="ka-btn ka-btn--ghost" id="ka-cta-appt" data-ka-appt-link>Book an Appointment</button>
      </div>

      <!-- Toast: shared component, CSS in ka-base.css, JS in ka-theme.js (window.kaShowToast) -->
      <div class="ka-toast" id="kaToast" role="status" aria-live="polite">
        <span class="ka-toast__mark" aria-hidden="true">&#10022;</span>
        <div class="ka-toast__body">
          <div class="ka-toast__title">Added to Your Bag</div>
          <div class="ka-toast__sub" id="kaToastSub">&nbsp;</div>
        </div>
        <a class="ka-toast__action" href="{{ routes.cart_url }}">View Bag &rarr;</a>
      </div>

      <!-- ASSURANCES -->
      <div class="ka-assure">
        <div class="ka-assure__row"><span class="mk" aria-hidden="true">&#10022;</span><span>Each piece is cut, draped and hand-embroidered to order by our karigars — never machine-made.</span></div>
        <div class="ka-assure__row"><span class="mk" aria-hidden="true">&#10022;</span><span>Complimentary worldwide delivery by DHL Express, beautifully packaged.</span></div>
        <div class="ka-assure__row"><span class="mk" aria-hidden="true">&#10022;</span><span>A personal advisor accompanies every order, confirming your measurements and fit after you enquire.</span></div>
      </div>

      <!-- ACCORDION -->
      <div class="ka-accordion" id="ka-accordion">
        <div class="ka-acc" data-acc="atelier">
          <button class="ka-acc__head" type="button">The Atelier Process<span class="ka-acc__pm" aria-hidden="true">+</span></button>
          <div class="ka-acc__body"><div class="ka-acc__inner">
            {%- if mf_atelier != blank -%}{{ mf_atelier }}{%- else -%}
              Every Karishma &amp; Ashita piece is made to measure. After your enquiry, our atelier cuts and constructs the garment to your individual measurements, then hand-embroiders the corset over several weeks before a final press and quality check. Your piece reaches you in {{ lead_time }}.
            {%- endif -%}
          </div></div>
        </div>
        <div class="ka-acc" data-acc="fabric">
          <button class="ka-acc__head" type="button">Fabric &amp; Embroidery<span class="ka-acc__pm" aria-hidden="true">+</span></button>
          <div class="ka-acc__body"><div class="ka-acc__inner">
            {%- if mf_fabric != blank -%}<p class="ka-acc__fabric-label"><strong>Fabric:</strong> {{ mf_fabric }}</p>{%- endif -%}
            <ul>
              <li>Natural-fibre base fabrics — naturally breathable, fluid and soothing to wear</li>
              {%- if mf_embroidery != blank -%}<li>{{ mf_embroidery | newline_to_br }}</li>{%- endif -%}
              <li>Concealed boning and structure for a sculpted, confident silhouette</li>
            </ul>
          </div></div>
        </div>
        <div class="ka-acc" data-acc="size">
          <button class="ka-acc__head" type="button">Size &amp; Fit Guide<span class="ka-acc__pm" aria-hidden="true">+</span></button>
          <div class="ka-acc__body"><div class="ka-acc__inner">
            {%- if mf_sizefit != blank -%}{{ mf_sizefit.content }}{%- else -%}
              All measurements in inches. For a true couture fit, select <em>Made to my measurements</em> and share your details with your style advisor.
              <table>
                <tr><th></th><th>Bust</th><th>Waist</th><th>Hip</th></tr>
                <tr><th>XS</th><td>32</td><td>26</td><td>35</td></tr>
                <tr><th>S</th><td>34</td><td>28</td><td>38</td></tr>
                <tr><th>M</th><td>36</td><td>30</td><td>39</td></tr>
                <tr><th>L</th><td>38</td><td>32</td><td>40</td></tr>
                <tr><th>XL</th><td>40</td><td>34</td><td>42</td></tr>
              </table>
            {%- endif -%}
          </div></div>
        </div>
        <div class="ka-acc" data-acc="delivery">
          <button class="ka-acc__head" type="button">Delivery &amp; Care<span class="ka-acc__pm" aria-hidden="true">+</span></button>
          <div class="ka-acc__body"><div class="ka-acc__inner">
            {%- if mf_delivery != blank -%}
              <p class="ka-acc__delivery-lead">Crafted to order in {{ lead_time }}.</p>
              {{ mf_delivery.content }}
            {%- else -%}
              <ul>
                <li>Crafted to order in {{ lead_time }}</li>
                <li>Complimentary worldwide shipping via DHL Express</li>
                <li>Dry clean only — store flat, away from direct light</li>
                <li>As each piece is made to measure, kindly review our exchange policy with your style advisor</li>
              </ul>
            {%- endif -%}
          </div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── Sticky minibar (desktop) ── -->
<div class="ka-minibar" id="ka-minibar">
  <div class="ka-minibar__in">
    <div class="ka-minibar__l">
      <div class="ka-minibar__thumb"{% if product.featured_image %} style="background-image:url('{{ product.featured_image | image_url: width: 120 }}');"{% endif %}></div>
      <div>
        <div class="ka-minibar__name">{{ product.title }}</div>
        <div class="ka-minibar__price"><span data-price="{{ product.price }}">{{ price }}</span>{% if product.collections.first %} · {{ product.collections.first.title }}{% endif %}</div>
      </div>
    </div>
    <div class="ka-minibar__r">
      <button type="button" class="ka-btn ka-btn--ghost" data-ka-appt-link>Book an Appointment</button>
      <button type="button" class="ka-btn ka-btn--bag" id="ka-minibar-bag" data-ka-add-to-bag aria-disabled="true">Add to Bag</button>
    </div>
  </div>
</div>

<!-- ── Mobile sticky action bar ── -->
<!-- "Appointment" + "Add to Bag" per Round 2; Concierge is kept as a
     secondary WhatsApp-questions affordance, not the primary buy path
     (CLAUDE.md: buy path stays clear/simple/primary; WhatsApp secondary). -->
<div class="ka-mobile-bar">
  <button type="button" class="ka-btn ka-btn--ghost" data-ka-appt-link>Appointment</button>
  <a class="ka-btn ka-btn--concierge" href="{{ wa_enquire }}" target="_blank" rel="noopener"><span class="dot"></span>Concierge</a>
  <button type="button" class="ka-btn ka-btn--bag" id="ka-mobilebar-bag" data-ka-add-to-bag aria-disabled="true">Add to Bag</button>
</div>

<!-- ── Lightbox (desktop/tablet only, disabled <900px via JS) ── -->
<div class="ka-lb" id="ka-lb">
  <span class="ka-lb__x" aria-hidden="true">Close &#10005;</span>
  <div class="ka-lb__frame" id="ka-lb-frame"></div>
</div>

<script src="{{ 'ka-product.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Product Main",
  "tag": "section",
  "settings": [
    { "type": "url",  "id": "appointment_url", "label": "Appointment booking URL (dormant — interim WhatsApp routing active)", "info": "Not currently used. \"Book an Appointment\" routes to WhatsApp until a real booking flow exists (Round 2, Docs/cta-architecture-revision.md). Kept here so a future booking flow has a ready setting to wire up." },
    { "type": "text", "id": "default_lead_time", "label": "Default lead time", "default": "20–25 days", "info": "Used when a product has no custom.lead_time metafield." },
    {
      "type": "header",
      "content": "Google rating row (sitewide aggregate)"
    },
    { "type": "text", "id": "rating_score", "label": "Rating score", "default": "4.9" },
    { "type": "text", "id": "rating_count", "label": "Review count", "default": "217" }
  ],
  "presets": [{ "name": "Product Main" }]
}
{% endschema %}
