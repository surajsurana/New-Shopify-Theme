{{ 'ka-cart-summary.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  K&A Cart ("Bag") Summary panel.
  Spec: Docs/cart-build-spec.md Section 3, F5.

  No WhatsApp concierge CTA on the filled-cart summary (per Suraj, 30 June
  2026 — overrides the earlier "Ask a Question Before You Checkout" CD
  decision for this specific spot). The only WhatsApp concierge CTA on this
  page lives in the empty-cart state (see ka-cart-items.liquid).

  Architecture note: this section closes the .ka-cart-wrap div opened by
  ka-cart-items.liquid — the two sections must stay pinned adjacent to each
  other in templates/cart.json.
{%- endcomment -%}

{%- if cart.item_count > 0 -%}
<div class="ka-cart-summary">
  <div class="ka-cart-summary__panel">
    <h2 class="ka-cart-summary__title">Order Summary</h2>

    <div class="ka-cart-summary__row">
      <span>Subtotal</span>
      <span>{{ cart.total_price | money }}</span>
    </div>
    <div class="ka-cart-summary__row ka-cart-summary__row--muted">
      <span>Shipping</span>
      <span>Calculated at checkout</span>
    </div>

    {%- if cart.cart_level_discount_applications.size > 0 -%}
      {%- for discount in cart.cart_level_discount_applications -%}
        <div class="ka-cart-summary__row ka-cart-summary__row--discount">
          <span>{{ discount.title }}</span>
          <span>&minus;{{ discount.total_allocated_amount | money }}</span>
        </div>
      {%- endfor -%}
    {%- endif -%}

    <div class="ka-cart-summary__row ka-cart-summary__row--total">
      <span>Estimated Total</span>
      <span>{{ cart.total_price | money }}</span>
    </div>

    <form action="{{ routes.cart_url }}" method="post" novalidate>
      <button type="submit" name="checkout" class="ka-btn ka-btn--full">Continue to Checkout</button>
    </form>

    <p class="ka-cart-summary__note">Complimentary worldwide shipping &middot; Taxes calculated at checkout</p>
  </div>
</div>
</div><!-- /.ka-cart-wrap (opened in ka-cart-items.liquid) -->
{%- endif -%}

{% schema %}
{
  "name": "Cart Summary",
  "tag": "div",
  "class": "ka-cart-summary-section",
  "settings": [],
  "presets": [
    { "name": "Cart Summary" }
  ]
}
{% endschema %}
