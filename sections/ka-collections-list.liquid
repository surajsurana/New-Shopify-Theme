{{ 'ka-collections-list.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  K&A All Collections Index (soft-launch placeholder)

  Fallback for the nav's "/collections" link (already live in every page's
  header). Built so that link has somewhere real to go instead of
  dead-ending or rendering Shopify's bare default collections-list markup.

  Curated, block-based list (matches the convention already used by
  sections/ka-bestsellers.liquid's native "collection" setting type) —
  merchant picks which collections show via Theme Customizer blocks,
  instead of this section auto-looping over every published collection.
  Reuses the exact same card markup/CSS classes as
  ka-collections-directory.liquid (.ka-coll-card and children) for visual
  consistency with the rest of the site.

  Per Suraj (2026-06-30): replaced the old "loop over every real
  collection" version because it was surfacing unfinished/test/internal
  collections he doesn't want customer-facing. Defaulted in
  templates/list-collections.json to his 5 named collections: The Festive
  Edit, The Bloom Soirée, Chamakk, Barre Oblique, The Wedding Festive
  Collection. He (or Creative Director) can add/remove/reorder via
  Theme Customizer blocks at any time — no code change needed.

  This is NOT the final design for this page — it gets its own real
  design later through the normal Creative-Director-approved pipeline,
  same as every other non-core page.
{%- endcomment -%}

<section class="ka-collections-list" aria-label="All collections">
  <div class="ka-collections-list__inner">
    <div class="ka-collections-list__header">
      <p class="eyebrow eyebrow--on-dark" style="margin-bottom: 16px;">{{ section.settings.eyebrow }}</p>
      <h1 class="ka-collections-list__title">{{ section.settings.title }}</h1>
    </div>

    {% liquid
      assign visible_blocks = 0
      for block in section.blocks
        if block.settings.collection != blank
          assign visible_blocks = visible_blocks | plus: 1
        endif
      endfor
    %}

    {% if visible_blocks > 0 %}
      <div class="ka-collections-list__grid">
        {% for block in section.blocks %}
          {% assign coll = block.settings.collection %}
          {% if coll != blank %}
            <a href="{{ coll.url }}" class="ka-coll-card" {{ block.shopify_attributes }}>
              <div class="ka-coll-card__image">
                {% if coll.image != blank %}
                  <img
                    src="{{ coll.image | image_url: width: 700 }}"
                    alt="{{ coll.image.alt | escape | default: coll.title | escape }}"
                    loading="lazy"
                    width="700"
                    height="1050"
                    class="img-filter-collection"
                  />
                {% else %}
                  <div style="background: var(--c-charcoal-2); width:100%; height:100%;"></div>
                {% endif %}
              </div>
              <div class="ka-coll-card__overlay"></div>
              <div class="ka-coll-card__label">
                <p class="ka-coll-card__number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</p>
                <h3 class="ka-coll-card__name">{{ coll.title }}</h3>
                <span class="ka-coll-card__arrow">Explore &rarr;</span>
              </div>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <p class="ka-collections-list__empty">{{ section.settings.empty_state_text }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Collections List",
  "tag": "section",
  "class": "ka-collections-list-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Curated /collections index. Add a block per collection you want shown (Theme Customizer), pick the collection in each block, reorder by dragging blocks. Defaults to 5 collections set in the template — edit anytime, no code change needed."
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Maison" },
    { "type": "text", "id": "title",   "label": "Page title", "default": "All Collections" },
    { "type": "text", "id": "empty_state_text", "label": "Empty state text", "default": "Collections are being prepared — please check back shortly, or explore our Signature edit." }
  ],
  "blocks": [
    {
      "type": "featured_collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" }
      ]
    }
  ],
  "presets": [
    { "name": "Collections List" }
  ]
}
{% endschema %}
