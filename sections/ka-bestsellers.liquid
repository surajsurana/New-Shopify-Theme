{{ 'ka-bestsellers.css' | asset_url | stylesheet_tag }}

<section class="ka-bestsellers" aria-label="Bestselling pieces">
  <div class="section-header">
    <div>
      <p class="eyebrow eyebrow--muted reveal">{{ section.settings.eyebrow }}</p>
      <h2 class="section-header__title reveal reveal-delay-1">{{ section.settings.title }}</h2>
    </div>
    <a href="{{ section.settings.view_all_url }}" class="section-header__link reveal reveal-delay-2">
      {{ section.settings.view_all_label }}
    </a>
  </div>

  <div class="ka-bestsellers__grid">
    {% assign product_1 = section.settings.product_1 %}
    {% assign product_2 = section.settings.product_2 %}
    {% assign product_3 = section.settings.product_3 %}

    {% for i in (1..3) %}
      {% assign product = section.settings["product_" | append: i] %}
      {% if product != blank %}
        <div class="ka-product-card reveal-img">
          <div class="ka-product-card__image">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 800 }}"
                alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
                loading="lazy"
                width="800"
                height="1067"
                class="img-filter-product"
              />
            {% endif %}
            {% if product.tags contains 'made-to-order' or product.tags contains 'Made to Order' %}
              <span class="ka-product-card__badge">Made to Order</span>
            {% endif %}
          </div>
          <div class="ka-product-card__info">
            <h3 class="ka-product-card__name">{{ product.title }}</h3>
            {% if product.metafields.custom.fabric_description != blank %}
              <p class="ka-product-card__fabric">{{ product.metafields.custom.fabric_description }}</p>
            {% endif %}
            <p class="ka-product-card__price">{{ product.price | money }}</p>
          </div>
          <a href="{{ product.url }}" class="ka-product-card__action">View piece &rarr;</a>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Bestsellers",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow",    "default": "Most Loved" },
    { "type": "text", "id": "title",   "label": "Section title", "default": "Signature Pieces" },
    { "type": "text", "id": "view_all_label", "label": "View all link label", "default": "View all bestsellers" },
    { "type": "url",  "id": "view_all_url",   "label": "View all link URL" },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Product 1",
      "info": "Ensure product has tag 'made-to-order' for badge. Set metafield custom.fabric_description for fabric line."
    },
    { "type": "product", "id": "product_2", "label": "Product 2" },
    { "type": "product", "id": "product_3", "label": "Product 3" }
  ],
  "presets": [
    { "name": "Bestsellers" }
  ]
}
{% endschema %}
