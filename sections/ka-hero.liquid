{{ 'ka-hero.css' | asset_url | stylesheet_tag }}
{{ 'ka-animations.css' | asset_url | stylesheet_tag }}

<section class="ka-hero" aria-label="Opening editorial">
  <div class="ka-hero__bg reveal-img" id="ka-hero-bg">
    {% if section.settings.hero_image != blank %}
      <img
        src="{{ section.settings.hero_image | image_url: width: 1800 }}"
        alt="{{ section.settings.hero_image.alt | escape | default: 'K&A Bridal Couture — opening editorial' }}"
        loading="eager"
        fetchpriority="high"
        width="1800"
        height="1200"
        class="img-filter-hero"
      />
    {% else %}
      <img
        src="https://karishmaashita.com/cdn/shop/files/KARISHMA_ASHITA_1_JUNE_2025_0968.jpg?v=1751529035&width=1800"
        alt="K&A Bridal Couture — opening editorial"
        loading="eager"
        fetchpriority="high"
        width="1800"
        height="1200"
        class="img-filter-hero"
      />
    {% endif %}
  </div>
  <div class="ka-hero__overlay"></div>

  <div class="ka-hero__content">
    <p class="ka-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="ka-hero__title">
      {{ section.settings.title_line1 }}<br>
      <strong>{{ section.settings.title_line2 }}</strong>
    </h1>
    <p class="ka-hero__sub">{{ section.settings.subtitle }}</p>
    <div class="ka-hero__ctas">
      <a href="{{ section.settings.cta_primary_url }}" class="btn-ghost">{{ section.settings.cta_primary_label }}</a>
      {%- comment -%}
        Secondary CTA ("Book a Styling Appointment") — TEMPORARY interim
        WhatsApp routing, same pattern as the Product page / mobile nav
        drawer (Docs/cta-architecture-revision.md Round 2, R2-4). There is
        no live appointments page yet, so this is marked data-ka-appt-link
        and intercepted by the sitewide delegated click handler in
        ka-nav.liquid, which opens https://wa.me/{{ settings.whatsapp_number }}
        instead. cta_secondary_url is kept as the real href so the link still
        goes somewhere sane if JS fails to load, and so the setting is ready
        to use as-is once a real booking flow exists (remove data-ka-appt-link
        at that point and this reverts to a normal configurable link).
      {%- endcomment -%}
      <a href="{{ section.settings.cta_secondary_url }}" class="btn-text" data-ka-appt-link>{{ section.settings.cta_secondary_label }}</a>
    </div>
  </div>

  <div class="ka-hero__scroll" aria-hidden="true">
    <span>Scroll</span>
    <div class="ka-hero__scroll-line"></div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image",
      "info": "Recommended: 1800px wide. The existing K&A editorial image is already in Files — select it here."
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Mumbai — Est. in Craft" },
    { "type": "text", "id": "title_line1", "label": "Title line 1 (italic)", "default": "Bridal" },
    { "type": "text", "id": "title_line2", "label": "Title line 2 (roman, small)", "default": "Couture" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Made-to-order bridal wear — corsets, lehengas, Indo-Western — conceived in Mumbai and worn across the world." },
    {
      "type": "header",
      "content": "CTAs"
    },
    { "type": "text", "id": "cta_primary_label",   "label": "Primary CTA label",   "default": "Explore Collections" },
    { "type": "url",  "id": "cta_primary_url",     "label": "Primary CTA URL" },
    { "type": "text", "id": "cta_secondary_label", "label": "Secondary CTA label", "default": "Book a Styling Appointment" },
    { "type": "url",  "id": "cta_secondary_url",   "label": "Secondary CTA URL" }
  ],
  "presets": [
    { "name": "Hero" }
  ]
}
{% endschema %}
