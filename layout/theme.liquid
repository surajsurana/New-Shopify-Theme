<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    {% if page_title == shop.name %}
      {{ shop.name }} — Bridal Couture, Mumbai
    {% else %}
      {{ page_title }} — {{ shop.name }}
    {% endif %}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}" />
  {% endif %}

  {%- liquid
    assign og_image = page_image | default: settings.share_image
  -%}
  {% if og_image %}
    <meta property="og:image" content="{{ og_image | image_url: width: 1200 }}" />
  {% endif %}

  <!-- Canonical -->
  <link rel="canonical" href="{{ canonical_url }}" />

  <!-- Google Fonts preconnect (required before font link) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Google Fonts: Cormorant Garamond + Jost (exact weights from spec v2.0) -->
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap"
    rel="stylesheet"
  />

  <!-- Global design tokens + reset -->
  {{ 'ka-base.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}
</head>

<body class="template-{{ request.page_type }}">
  {{ content_for_layout }}

  <!-- Global floating concierge button — renders on every page (z-index 110) -->
  {% render 'ka-concierge-float' %}

  <!-- Global theme JS: nav scroll, reveals, parallax, mobile nav, newsletter -->
  <script src="{{ 'ka-theme.js' | asset_url }}" defer></script>
</body>
</html>
