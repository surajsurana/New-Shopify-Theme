{%- comment -%}
  K&A Search Overlay — full-viewport takeover.
  Built from Prototypes/search-404-footer-v1.html, "2 — SEARCH OVERLAY" block.
  Spec: Docs/search-404-footer-build-spec.md, Section 1.

  Rendered once, inline, from sections/ka-nav.liquid (same pattern already used
  for the mobile nav drawer and the shared currency menu in that file) — NOT a
  separate section requiring duplication across every template's "order" array,
  since it carries no per-template content and only needs to exist once, sitewide.

  Three states, toggled by assets/ka-search.js:
    1. Empty  (#ka-search-empty)      — query < 2 chars. Popular-search chips
       (.ka-chip, same component as the Collection refine bar) + 3 image tiles.
       Content comes from ka-nav section settings (search_chip_*, search_tile_*)
       so Suraj can edit labels/images/URLs from the theme editor.
    2. Results (#ka-search-results)   — query >= 2 chars, matches found. The
       inner grid (#ka-search-results-content) is replaced wholesale by an HTML
       fragment fetched from Shopify's native Predictive Search Section
       Rendering endpoint (sections/ka-predictive-search.liquid), which renders
       the real .ka-p-card component verbatim — no hand-built JS card template.
    3. No-results (#ka-search-noresults) — query >= 2 chars, zero matches.
       Concierge WhatsApp fallback + Browse All Collections, same pattern as
       ka-404.liquid / ka-collection-grid.liquid's empty state.

  The visible input is inside a real <form action="/search" method="get"> with
  a hidden type=product field, so Enter / "View All Results" work with zero JS
  (progressive enhancement) and land on templates/search.json (sections/ka-search-results.liquid).
{%- endcomment -%}

<div class="ka-search-overlay" id="ka-search-overlay" role="dialog" aria-modal="true" aria-hidden="true" aria-label="Search">
  <button type="button" class="ka-search-overlay__close" id="ka-search-close">Close</button>
  <div class="ka-search-overlay__inner">
    <p class="eyebrow ka-search-overlay__eyebrow">Search</p>
    <form action="/search" method="get" id="ka-search-form">
      <input type="hidden" name="type" value="product" />
      <div class="ka-search-overlay__field">
        <input
          type="search"
          name="q"
          class="ka-search-overlay__input"
          id="ka-search-input"
          placeholder="Search pieces, collections, stories…"
          autocomplete="off"
          aria-label="Search pieces, collections, stories"
        />
      </div>
    </form>

    <!-- Empty state -->
    <div id="ka-search-empty">
      <p class="eyebrow ka-search-empty__label">Popular Searches</p>
      <div class="ka-search-empty__chips">
        {%- comment -%}
          Five discrete label/url setting pairs rather than a blocks
          array — the layout is fixed (5 chips, matching the prototype's
          real collection list exactly), so this stays editable from the
          theme editor (spec's "Suraj can edit content" requirement)
          without the extra complexity of a block type nobody needs to
          reorder or add to.
        {%- endcomment -%}
        {%- if section.settings.search_chip_1_label != blank -%}<a href="{{ section.settings.search_chip_1_url | default: '/collections' }}" class="ka-chip" data-ka-search-chip data-query="{{ section.settings.search_chip_1_label }}">{{ section.settings.search_chip_1_label }}</a>{%- endif -%}
        {%- if section.settings.search_chip_2_label != blank -%}<a href="{{ section.settings.search_chip_2_url | default: '/collections' }}" class="ka-chip" data-ka-search-chip data-query="{{ section.settings.search_chip_2_label }}">{{ section.settings.search_chip_2_label }}</a>{%- endif -%}
        {%- if section.settings.search_chip_3_label != blank -%}<a href="{{ section.settings.search_chip_3_url | default: '/collections' }}" class="ka-chip" data-ka-search-chip data-query="{{ section.settings.search_chip_3_label }}">{{ section.settings.search_chip_3_label }}</a>{%- endif -%}
        {%- if section.settings.search_chip_4_label != blank -%}<a href="{{ section.settings.search_chip_4_url | default: '/collections' }}" class="ka-chip" data-ka-search-chip data-query="{{ section.settings.search_chip_4_label }}">{{ section.settings.search_chip_4_label }}</a>{%- endif -%}
        {%- if section.settings.search_chip_5_label != blank -%}<a href="{{ section.settings.search_chip_5_url | default: '/collections' }}" class="ka-chip" data-ka-search-chip data-query="{{ section.settings.search_chip_5_label }}">{{ section.settings.search_chip_5_label }}</a>{%- endif -%}
      </div>
      <div class="ka-search-empty__tiles">
        {%- if section.settings.search_tile_1_caption != blank -%}
          <a href="{{ section.settings.search_tile_1_url | default: '/collections' }}" class="ka-search-empty__tile">
            {%- if section.settings.search_tile_1_image != blank -%}
              <img src="{{ section.settings.search_tile_1_image | image_url: width: 600 }}" alt="{{ section.settings.search_tile_1_caption | escape }}" loading="lazy" width="600" height="800" />
            {%- else -%}
              <img src="{{ 'bloom-soiree-card.jpg' | asset_url }}" alt="{{ section.settings.search_tile_1_caption | escape }}" loading="lazy" width="600" height="800" />
            {%- endif -%}
            <span>{{ section.settings.search_tile_1_caption }}</span>
          </a>
        {%- endif -%}
        {%- if section.settings.search_tile_2_caption != blank -%}
          <a href="{{ section.settings.search_tile_2_url | default: '/collections' }}" class="ka-search-empty__tile">
            {%- if section.settings.search_tile_2_image != blank -%}
              <img src="{{ section.settings.search_tile_2_image | image_url: width: 600 }}" alt="{{ section.settings.search_tile_2_caption | escape }}" loading="lazy" width="600" height="800" />
            {%- else -%}
              <img src="{{ 'chamak-card.jpg' | asset_url }}" alt="{{ section.settings.search_tile_2_caption | escape }}" loading="lazy" width="600" height="800" />
            {%- endif -%}
            <span>{{ section.settings.search_tile_2_caption }}</span>
          </a>
        {%- endif -%}
        {%- if section.settings.search_tile_3_caption != blank -%}
          <a href="{{ section.settings.search_tile_3_url | default: '/collections' }}" class="ka-search-empty__tile">
            {%- if section.settings.search_tile_3_image != blank -%}
              <img src="{{ section.settings.search_tile_3_image | image_url: width: 600 }}" alt="{{ section.settings.search_tile_3_caption | escape }}" loading="lazy" width="600" height="800" />
            {%- else -%}
              <img src="{{ 'barre-card.jpg' | asset_url }}" alt="{{ section.settings.search_tile_3_caption | escape }}" loading="lazy" width="600" height="800" />
            {%- endif -%}
            <span>{{ section.settings.search_tile_3_caption }}</span>
          </a>
        {%- endif -%}
      </div>
    </div>

    <!-- Results state -->
    <div id="ka-search-results" style="display:none;">
      <div id="ka-search-results-content"><!-- filled by assets/ka-search.js via Section Rendering fetch --></div>
      <div class="ka-search-results__more">
        <a href="/search?q=&amp;type=product" class="btn-dark" id="ka-search-view-all">View All Results</a>
      </div>
    </div>

    <!-- No-results state -->
    <div id="ka-search-noresults" class="ka-search-noresults" style="display:none;">
      <p class="ka-search-noresults__title" id="ka-search-noresults-title">We couldn't find that piece</p>
      <p class="ka-search-noresults__body">Our styling concierge knows every piece in the atelier — send us a message and we'll help you find exactly what you're picturing.</p>
      <div class="ka-search-noresults__actions">
        <a
          href="https://wa.me/{{ settings.whatsapp_number }}?text={{ 'Hi, I could not find what I was looking for on your website. Could you help?' | url_param_escape }}"
          target="_blank" rel="noopener" class="btn-outline-rose"
        >Ask Our Styling Concierge</a>
        <a href="/collections" class="btn-dark">Browse All Collections</a>
      </div>
    </div>
  </div>
</div>
